{
  "name": "@pagopa/it-wallet-conformance-test",
  "description": "Automated conformance testing for IT Wallet ecosystem services",
  "packageManager": "pnpm@10.23.0",
  "version": "1.1.5",
  "type": "module",
  "main": "./dist/cli.js",
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "bin",
    "config.example.ini",
    "dist",
    "dumps",
    "vitest.common.js",
    "vitest.issuance.config.js",
    "vitest.presentation.config.js"
  ],
  "bin": {
    "wct": "./bin/wct"
  },
  "scripts": {
    "build": "node scripts/build.ts --production",
    "ta:server": "tsx src/servers/ta-server.ts",
    "wp:server": "tsx src/servers/wp-server.ts",
    "ci:server": "tsx src/servers/ci-server.ts",
    "servers": "concurrently \"pnpm ta:server\" \"pnpm wp:server\" \"pnpm ci:server\"",
    "types:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:unit": "vitest --config vitest.unit.config.js",
    "format": "prettier --write \"{src,tests}/**/*.{js,ts}\"",
    "format:check": "prettier --check \"{src,tests}/**/*.{js,ts}\"",
    "lint": "eslint --fix \"{src,tests}/**/*.{js,ts}\"",
    "lint:check": "eslint \"{src,tests}/**/*.{js,ts}\"",
    "pre-commit": "pnpm format && pnpm lint && pnpm types:check",
    "prepare": "husky",
    "code-review": "pnpm types:check && pnpm lint:check && pnpm format:check && pnpm -r build",
    "test:issuance": "vitest run --config vitest.issuance.config.js",
    "test:issuance:ui": "vitest --config vitest.issuance.config.js --ui",
    "test:presentation": "vitest run --config vitest.presentation.config.js",
    "prepublish": "pnpm build"
  },
  "keywords": [
    "wallet",
    "conformance",
    "testing",
    "tool",
    "cli"
  ],
  "author": "PagoPa S.p.A.",
  "license": "ISC",
  "devDependencies": {
    "@pagopa/eslint-config": "^5.0.1",
    "@types/express": "^5.0.3",
    "@types/ini": "^4.1.1",
    "@types/node": "^24.1.0",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.38.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "tsx": "^4.22.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["puppeteer"]
  },
  "dependencies": {
    "@auth0/mdl": "^3.0.0",
    "@pagopa/io-wallet-oauth2": "1.5.2",
    "@pagopa/io-wallet-oid-federation": "1.5.2",
    "@pagopa/io-wallet-oid4vci": "1.5.2",
    "@pagopa/io-wallet-oid4vp": "1.5.2",
    "@pagopa/io-wallet-utils": "1.5.2",
    "@peculiar/x509": "^1.14.3",
    "@sd-jwt/core": "^0.17.0",
    "@sd-jwt/crypto-nodejs": "^0.17.0",
    "@sd-jwt/decode": "^0.17.0",
    "@sd-jwt/jwt-status-list": "^0.19.0",
    "@sd-jwt/sd-jwt-vc": "^0.17.1",
    "@sd-jwt/types": "^0.17.0",
    "cbor": "^10.0.11",
    "commander": "^14.0.2",
    "consola": "^3.4.2",
    "dcql": "^3.0.0",
    "express": "^5.2.1",
    "ini": "^5.0.0",
    "jose": "^6.1.0",
    "puppeteer": "^25.1.0",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  }
}
